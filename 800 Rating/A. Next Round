#include <bits/stdc++.h>
using namespace std;
 
int main() 
{
    int n,k,i,minimum;
    int count=0;
    cin>>n>>k;
    
    vector<int>a(n);
    
    for(i=0;i<n;i++)
    {
      cin>>a[i];
      minimum=a[k-1];
      if(a[i]>=minimum && a[i]!=0)
      count++;
    }
cout<<count;
 
 
 
  return 0;
}
