#include <iostream>
using namespace std;
 
int main() 
{
    int i,n,t,a;
    cin>>t;
    
    while(t--)
    {
      cin>>n;
      bool got67=false;
      for(i=0;i<n;i++)
      {
        cin>>a;
        if(a==67)
        got67=true;
        
      }
      cout<<(got67?"YES\n":"NO\n");
    }
}
