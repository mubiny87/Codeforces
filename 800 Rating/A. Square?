// Problem: A. Square?
// Rating: 800

#include <iostream>
using namespace std;
 
int main() 
{
    int n,a,b,c,d;
    cin>>n;
    for(int i=0;i<n;i++)
    {
      cin>>a>>b>>c>>d;
      if(a!=b)
        {
          cout<<"NO"<<endl;
        }
        else
        {
          if(b!=c)
          {
            cout<<"NO"<<endl;
          }
          else
          {
            if(c!=d)
            {
              cout<<"NO"<<endl;
            }
            else
            {
              cout<<"YES"<<endl;
          } }
        }
    }
    
}
