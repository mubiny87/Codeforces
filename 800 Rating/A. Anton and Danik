#include <bits/stdc++.h>
#include<cstring>
using namespace std;
 
int main() 
{
  int i,n;
  string s;
  cin>>n;
  cin>>s;
  
  int a=0,d=0;
  
  for(char c:s)
  {
    if(c=='A')
    a++;
    else d++;
  }
  
  if(a>d)
  cout<<"Anton";
  else if(d>a)
  cout<<"Danik";
  else
  cout<<"Friendship";
  
  return 0;
}
