#include <iostream>
using namespace std;
 
int main() 
{
    int n;
    cin>>n;
    
    int a,b,c;
    int sumx=0,sumy=0,sumz=0;
    while(n--)
    {
      cin>>a>>b>>c;
      sumx+=a;sumy+=b;sumz+=c;
    }
 
if(sumx==0&&sumy==0&&sumz==0)
cout<<"YES";
else
cout<<"NO";
 
    return 0;
}
